{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["syd1"],
  "crons": [
    {
      "path": "/api/guild/cron/retention-check",
      "schedule": "15 13 * * *"
    },
    {
      "path": "/api/guild/cron/monthly-close",
      "schedule": "30 13 1 * *"
    },
    {
      "path": "/api/cron/stripe-reconcile",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/compliance-export-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/analyst-weekly-generate",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/pipeline-health",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/alert-dispatch",
      "schedule": "* * * * *"
    }
  ]
}
