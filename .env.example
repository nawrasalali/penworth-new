# ===========================================
# PENWORTH NEW - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# 
# IMPORTANT: This is PENWORTH NEW (v2.0) - the rebuilt platform
# Distinct from legacy penworth.ai to avoid confusion

# ===========================================
# SUPABASE (Create NEW project: penworth-new-prod)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_NEW_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===========================================
# ANTHROPIC (Claude API)
# ===========================================
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ===========================================
# STRIPE (Use existing account, new products)
# ===========================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_TEAM_MONTHLY=price_xxx

# ===========================================
# INNGEST (Background Jobs)
# ===========================================
INNGEST_SIGNING_KEY=signkey-xxx
INNGEST_EVENT_KEY=xxx

# ===========================================
# APPLICATION
# ===========================================
NEXT_PUBLIC_APP_URL=https://new.penworth.ai
NEXT_PUBLIC_APP_NAME=Penworth
